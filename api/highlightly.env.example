# Copy to the VM's protected environment file. Never commit real values.
HIGHLIGHTLY_API_KEY=replace-at-deploy
HIGHLIGHTLY_BASE_URL=https://sports.highlightly.net
HIGHLIGHTLY_ANALYSIS_ENABLED=false

# Required only by the server-side ingestion worker. Never expose this key to Vite.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-at-deploy

# Public build-time rollout flag. This is not a security boundary.
VITE_HIGHLIGHTLY_ANALYSIS_ENABLED=false
