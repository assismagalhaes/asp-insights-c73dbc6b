# Copy to the VM's protected environment file. Never commit real values.
HIGHLIGHTLY_API_KEY=replace-at-deploy
HIGHLIGHTLY_BASE_URL=https://sports.highlightly.net
HIGHLIGHTLY_ANALYSIS_ENABLED=false
# Optional hard ceiling for generic worker processes. Phase 7 calculates and injects its own ceiling.
HIGHLIGHTLY_DAILY_QUOTA_CEILING=

# Direct Supabase mode (self-managed deployments only). Never expose this key to Vite.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-at-deploy

# Lovable Cloud bridge mode (recommended for the external VM).
# Configure both values below and omit both SUPABASE_* values on the VM.
# The same secret must exist only in the Lovable server environment and this protected VM file.
HIGHLIGHTLY_INGEST_BRIDGE_URL=https://your-app.example.com/api/public/hooks/highlightly-ingest
HIGHLIGHTLY_INGEST_BRIDGE_SECRET=replace-with-at-least-32-random-characters

# Public build-time rollout flag. This is not a security boundary.
VITE_HIGHLIGHTLY_ANALYSIS_ENABLED=false
