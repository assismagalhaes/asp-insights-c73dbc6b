        "name": "list_prognosticos",
        "title": "Listar prognósticos",
        "description": "Lista os prognósticos mais recentes do usuário autenticado (jogo, mercado, odd, edge, resultado).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 10,
              "description": "Quantos prognósticos retornar.",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "esporte": {
              "description": "Filtrar por esporte (ex.: MLB, WNBA, Futebol).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_validacoes",
        "title": "Listar validações",
        "description": "Lista as validações de IA mais recentes do usuário (decisão, parecer, modo, prognóstico associado).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 10,
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "decisao": {
              "description": "Filtrar por decisão.",
              "type": "string",
              "enum": ["CONFIRMAR", "PULAR"]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "bankroll_status",
